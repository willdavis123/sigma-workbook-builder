# Secrets
.env
.env.*.local

# Personal Claude Code settings (per-user)
.claude/settings.local.json

# Vendor mirror of upstream skills (refresh via scripts/refresh-vendor.sh)
vendor/

# Iteration scratch
workbooks/*/iterations/*.tmp
workbooks/*/iterations/*.draft.json

# Local workbook iteration folders — only _template/ and _exemplars/ are
# repo-tracked; every other workbooks/<name>/ is per-author scratch.
workbooks/*/
!workbooks/_template/
!workbooks/_exemplars/

# Per-user session walkthroughs (not part of the skill itself)
docs/sessions/

# Training session summaries — per-author scratch, often customer-specific
prompts/library/train_*.md

# Phase 1 research artifact — competitor packaging review, internal-only
docs/twells89-review.md

# OS / editor noise
.DS_Store
.idea/
.vscode/
*.swp

# Token cache (if anything writes one locally)
.sigma-token

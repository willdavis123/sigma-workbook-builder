# Sigma REST API credentials.
# Copy this file to .env and fill in real values. .env is gitignored.
# Find these in Sigma: Administration -> APIs and Tokens (a.k.a. Developer Access -> API credentials).

# API host (NOT the app URL). Pick the one matching your org's cloud/region.
# Reference: https://help.sigmacomputing.com/docs/region-warehouse-and-feature-support
# Common defaults:
#   AWS US-West (Oregon):     https://aws-api.sigmacomputing.com
#   AWS US-East (N. Virginia): https://api.us-a.aws.sigmacomputing.com
#   GCP US (Iowa):            https://api.sigmacomputing.com
SIGMA_BASE_URL=https://aws-api.sigmacomputing.com

SIGMA_CLIENT_ID=
SIGMA_CLIENT_SECRET=
